{
  "name": "ghpr-three",
  "version": "0.1.0",
  "description": "Generalized Hidden Point Removal (GHPR) operator for three.js point clouds, with an R3F/drei playground.",
  "type": "module",
  "license": "MIT",
  "author": "Sungwoo Cho <sungwoo.cho.dev@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swcho/ghpr-three.git"
  },
  "homepage": "https://github.com/swcho/ghpr-three#readme",
  "bugs": {
    "url": "https://github.com/swcho/ghpr-three/issues"
  },
  "keywords": [
    "three",
    "threejs",
    "point-cloud",
    "hidden-point-removal",
    "hpr",
    "ghpr",
    "visibility",
    "convex-hull"
  ],
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --config vite.playground.config.ts",
    "build": "vite build",
    "prepublishOnly": "pnpm run typecheck && pnpm test && pnpm run build",
    "build:playground": "vite build --config vite.playground.config.ts",
    "preview": "vite preview --config vite.playground.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,js,cjs,json,css,md,html}\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "three": ">=0.150.0"
  },
  "devDependencies": {
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.10",
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "leva": "^0.9.35",
    "prettier": "^3.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^2.1.4"
  }
}
